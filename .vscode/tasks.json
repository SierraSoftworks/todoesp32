{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "core: test (host)",
      "type": "shell",
      "command": "cargo test -p todoesp-core",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "firmware: build",
      "type": "shell",
      "command": "cargo build",
      "options": {
        "cwd": "${workspaceFolder}/firmware",
        "env": {
          "RUSTUP_TOOLCHAIN": "esp"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "firmware: clippy",
      "type": "shell",
      "command": "cargo clippy -- -D warnings && cargo clippy --test integration -- -D warnings",
      "options": {
        "cwd": "${workspaceFolder}/firmware",
        "env": {
          "RUSTUP_TOOLCHAIN": "esp"
        }
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "firmware: run (flash + monitor)",
      "type": "shell",
      "command": "cargo run --release",
      "options": {
        "cwd": "${workspaceFolder}/firmware",
        "env": {
          "RUSTUP_TOOLCHAIN": "esp"
        }
      },
      "problemMatcher": ["$rustc"]
    }
  ]
}
